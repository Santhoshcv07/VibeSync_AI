# VibeSync AI Backend Environment Template
# Copy this file to .env only when local configuration begins.
# Never commit the real .env file.

# Application
APP_NAME=VibeSync AI API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1

# Server
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Frontend and CORS
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Database — configure when PostgreSQL integration begins
DATABASE_URL=postgresql+asyncpg://YOUR_DATABASE_USER:YOUR_DATABASE_PASSWORD@YOUR_DATABASE_HOST:5432/YOUR_DATABASE_NAME

# Authentication — configure when authentication implementation begins
AUTH_SECRET_KEY=YOUR_LONG_RANDOM_AUTH_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Future AI integration — disabled until the AI client is implemented
AI_ENABLED=false
AI_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama3-8b-8192

# Music provider — configure when music integration begins
SPOTIFY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID
SPOTIFY_CLIENT_SECRET=YOUR_SPOTIFY_CLIENT_SECRET

# YouTube provider — configure when YouTube integration begins
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY

# Visual provider — configure when visual integration begins
VISUAL_PROVIDER=YOUR_APPROVED_VISUAL_PROVIDER
VISUAL_PROVIDER_API_KEY=YOUR_VISUAL_PROVIDER_API_KEY

# Movie provider — configure when movie integration begins
TMDB_API_KEY=YOUR_TMDB_API_KEY

# Book provider — configure only if the approved provider requires a key
GOOGLE_BOOKS_API_KEY=YOUR_GOOGLE_BOOKS_API_KEY

# External-provider behavior
PROVIDER_TIMEOUT_SECONDS=10
PROVIDER_MAX_RETRIES=2

# Logging
LOG_LEVEL=INFO
