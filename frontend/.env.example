# VibeSync AI Frontend Environment Template
# Copy this file to .env.local only when local configuration begins.
# Never commit .env.local.

# Environment (development, test, production)
APP_ENV=development

# Public URL of the Next.js frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public URL used by the frontend to call the FastAPI backend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
